#!/bin/sh
# .git/hooks/pre-push
# Prevents direct pushes to main — use a PR branch instead.
#
# To bypass in an emergency: git push --no-verify
# To install this hook on a fresh clone: pwsh ./scripts/Install-GitHooks.ps1

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ]; then
  echo ""
  echo "  ✋ Direct push to 'main' is not allowed."
  echo ""
  echo "  Please create a branch and open a Pull Request instead:"
  echo "    git checkout -b <branch-name>"
  echo "    git push origin <branch-name>"
  echo ""
  echo "  To bypass in an emergency: git push --no-verify"
  echo ""
  exit 1
fi

exit 0
